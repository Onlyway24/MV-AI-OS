{
  "name": "mv-ai-os",
  "version": "0.1.0",
  "private": true,
  "description": "A modular AI operating system for coordinated agents, memory, tools, and workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mv-ai-os": "./dist/cli/local-runtime-cli.js",
    "mv-ai-os-command-center": "./dist/command-center/command-center-cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "22.23.x"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "cli": "node ./dist/cli/local-runtime-cli.js",
    "command-center": "node ./dist/command-center/command-center-cli.js",
    "lint": "eslint . --max-warnings 0",
    "telegram": "node ./dist/telegram/telegram-cli.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  }
}
