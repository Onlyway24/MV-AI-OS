{
  "name": "mv-ai-os",
  "version": "0.1.0",
  "private": true,
  "description": "A modular AI operating system for coordinated agents, memory, tools, and workflows.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "mv-ai-os": "./dist/cli/local-runtime-cli.js",
    "mv-ai-os-command-center": "./dist/command-center/command-center-cli.js",
    "mv-ai-os-operations": "./dist/operations-runtime/operations-runtime-cli.js",
    "mv-ai-os-revenue": "./dist/revenue-os/revenue-os-cli.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": "22.23.x"
  },
  "packageManager": "npm@10.9.8",
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
    "cli": "node ./dist/cli/local-runtime-cli.js",
    "command-center": "node ./dist/command-center/command-center-cli.js",
    "live-media-pilot": "node ./dist/media-factory/live-ai-brand-media-pilot-cli.js",
    "media-quality-closure": "node ./dist/media-factory/media-quality-closure-cli.js",
    "image-recovery": "node ./dist/media-factory/image-recovery-cli.js",
    "openai-responses-conformance": "node ./dist/media-factory/openai-responses-conformance-cli.js",
    "openai-text-diagnosis": "node ./dist/media-factory/openai-text-failure-diagnosis-cli.js",
    "operations": "node ./dist/operations-runtime/operations-runtime-cli.js",
    "revenue-os": "node ./dist/revenue-os/revenue-os-cli.js",
    "social-connectors": "node ./dist/social-publishing/social-connector-cli.js",
    "lint": "eslint . --max-warnings 0",
    "telegram": "node ./dist/telegram/telegram-cli.js",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json",
    "check": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/node": "22.20.0",
    "eslint": "10.6.0",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vitest": "4.1.9"
  },
  "dependencies": {
    "motion": "^12.42.2"
  }
}
